@inject ThemeService ThemeService
@inject IDialogService DialogService

<MudPaper Elevation="0" Class="pa-4 d-flex justify-space-between align-center component">

    <MudText Typo="Typo.caption">
        © @(DateTime.Now.Year) Giulio Porcu
    </MudText>
    <MudButton
               Variant="Variant.Text"
               Size="Size.Small"
               Class="footer-fab"
               OnClick="@OpenColorPickerAsync">
        <MudIcon Icon="@Icons.Material.Filled.Palette" />
    </MudButton>
</MudPaper>

@code {
    /// <summary>
    /// Opens the theme color picker dialog.
    /// </summary>
    /// <remarks>
    /// Displays the color picker dialog to allow the user to modify theme settings.
    /// </remarks>
    private async Task OpenColorPickerAsync()
    {
        IDialogReference dialog = await DialogService.ShowAsync<ColorPickerDialog>();
        await dialog.Result;
        await ThemeService.PersistAsync();
    }
}