@page "/"
@page "/login"
@using System.Security

@layout LoginLayout

@inject NavigationManager NavigationManager
@inject LoadingService LoadingService
@inject DiscogsClient DiscogsClient
@inject LocalStorageService LocalStorageService
@inject ISnackbar Snackbar

<MudOverlay Visible="LoadingService.IsLoading" DarkBackground="true">
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
</MudOverlay>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="d-flex justify-center mt-12 ">
    <MudCard Class="pa-6 component" Style="width: 100%; ">
        <MudText Typo="Typo.h5" Class="mb-4">
            Login
        </MudText>
        <MudTextField @bind-Value="Token"
                      Label="@(Messages.ApiToken)"
                      Variant="Variant.Outlined"
                      InputType="@(ShowPassword? InputType.Text: InputType.Password)"
                      Class="mb-4"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(ShowPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                      OnAdornmentClick="TogglePasswordVisibility"
                      IconSize="Size.Medium" />
        <MudCheckBox T="bool" Label="Remember Token" Class="mb-4" @bind-Value="this.RememberMe" Color="Color.Primary" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoginAsync" FullWidth="true">
            Login
        </MudButton>
    </MudCard>
</MudContainer>

@code {
    private const string REMEMBER_TOKEN_KEY = "remember-token";
    private const string TOKEN_KEY = "token";
    private const string REMEMBER_TOKEN_TRUTHY = "T";


    private string? Token { get; set; }
    private bool RememberMe { get; set; }
    private bool ShowPassword { get; set; }

    protected async override Task OnInitializedAsync()
    {
        this.RememberMe = await LocalStorageService.GetAsync(REMEMBER_TOKEN_KEY) == REMEMBER_TOKEN_TRUTHY;

        if (this.RememberMe && await LocalStorageService.GetDecryptedAsync(TOKEN_KEY) is string token)
        {
            this.Token = token;
        }

        this.LoadingService.OnChanged += StateHasChanged;

    }

    private void TogglePasswordVisibility()
    {
        this.ShowPassword = !this.ShowPassword;
    }


    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(this.Token))
        {
            this.Snackbar.Add(Messages.InvalidApiToken, Severity.Error);
            return;
        }

        if (this.RememberMe)
        {
            await this.LocalStorageService.SetAsync(REMEMBER_TOKEN_KEY, REMEMBER_TOKEN_TRUTHY);
            await this.LocalStorageService.SetEncryptedAsync(TOKEN_KEY, this.Token ?? string.Empty);
        }
        else
        {
            await this.LocalStorageService.RemoveAsync(REMEMBER_TOKEN_KEY);
            await this.LocalStorageService.RemoveAsync(TOKEN_KEY);
        }

        if (await this.DiscogsClient.AuthenticateAsync(this.Token ?? string.Empty))
        {
            this.Snackbar.Add($"Hello {this.DiscogsClient.User?.UserName ?? "N/A"}", Severity.Success);
            // this.NavigationManager.NavigateTo("/");
        }
        else
        {
            this.Snackbar.Add(Messages.FailedToAuthenticate, Severity.Error);
        }
    }
}